<!doctype html>
<html lang="es">
<head>
	<meta charset="utf-8">
	<meta name="description" content="">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Centro de estudiantes ET 17 DE 13 Brig. Gral. Cornelio Saavedra- Panel</title>
	<link href="https://getbootstrap.com/docs/5.2/dist/css/bootstrap.min.css" rel="stylesheet">	
	<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
	<link rel="icon" type="image/x-icon" href="/logo.png">
	<link rel="author" href="Ignacio Fernandez">
</head>
<body>
	<div class="row" style="height: 100vh">
		<div class="col-md-2 d-sm-none d-md-flex flex-column flex-shrink-0 p-3 bg-light h-100">
			<a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-dark text-decoration-none">
				<img src="../logo.png" alt="logo" width="80" height="80">
			</a>
			<hr>
			<ul class="nav nav-pills flex-column mb-auto">
				<li class="nav-item">
					<a href="#Inicio" class="nav-link active" aria-current="page">
						<svg class="bi pe-none me-2" width="16" height="16"><use xlink:href="#home"></use></svg>
						Inicio
					</a>
				</li>
				<li>
					<a href="#Noticias" id="Noticias" class="nav-link">
						<svg class="bi pe-none me-2" width="16" height="16"><use xlink:href="#speedometer2"></use></svg>
						Noticias
					</a>
				</li>
				<li>
					<a href="#Listado" id="Listado" class="nav-link">
						<svg class="bi pe-none me-2" width="16" height="16"><use xlink:href="#table"></use></svg>
						Listado
					</a>
				</li>
			</ul>
			<hr>
			<div class="dropdown">
				<a href="#" class="d-flex align-items-center link-dark text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
					<img src="https://github.com/mdo.png" alt="" class="rounded-circle me-2" width="32" height="32">
					<strong>mdo</strong>
				</a>
				<ul class="dropdown-menu text-small shadow">
					<li><a class="dropdown-item" href="#">New project...</a></li>
					<li><a class="dropdown-item" href="#">Settings</a></li>
					<li><a class="dropdown-item" href="#">Profile</a></li>
					<li><hr class="dropdown-divider"></li>
					<li><a class="dropdown-item" href="#">Sign out</a></li>
				</ul>
			</div>
		</div>	
		<div class="col-sm-12 col-md-10">
			<div class="container-fluid p-5">
				<div class="content"></div>
			</div>
		</div>		
	</div>
</body>
	<script src="https://code.jquery.com/jquery-3.6.3.min.js"></script>
	<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
	<script>
		$("document").ready(()=>{
			$("#Noticias").click(()=>{
				$(".active").removeClass("active")
				$("#Noticias").addClass("active")
				$(".content").empty()

				$(".content").append(`
					<div id="editor" style="height: 50vh"></div>
					<div class="mt-2 float-end">
						<button type="button" class="btn btn-primary" id="Send">Subir noticia</button>
					</div>
				`)
				var quill = new Quill('#editor', {
    				theme: 'snow'
  				});

				$("#Send").click(()=>{
					console.log(`
						${$("#editor").find("h1").html()}
					`)
					$.post("/noticia/subir", {
						titulo: $("#editor").find("h1").html(),
						subtitulo: $("#editor").find("h3").html(),
						nota: $("#editor").find("p").html()
					}, ()=>{
						console.log("Noticia subida")
					})
				})			
			})
		})
	</script>
</html>